# Pik Dame - hardened Caddyfile (production reverse proxy)
# Domain and ACME e-mail come from the environment (.env next to the
# compose file): PIKDAME_DOMAIN, ACME_EMAIL.
{
	# No runtime admin API - configuration changes go through redeploys.
	admin off
	# ACME account e-mail for Let's Encrypt (expiry notices etc.)
	email {$ACME_EMAIL}

	# CrowdSec bouncer (compiled in via docker/caddy/Dockerfile): asks the
	# local CrowdSec API for every request and blocks banned IPs.
	# The API key is created once via: cscli bouncers add caddy-bouncer
	crowdsec {
		api_url http://crowdsec:8080
		api_key {$CROWDSEC_API_KEY}
	}
	order crowdsec first
}

{$PIKDAME_DOMAIN} {
	crowdsec
	encode zstd gzip

	header {
		# TLS-only from here on (browsers remember for a year)
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		# The game is never meant to be embedded
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		# Do not advertise the server software
		-Server
		# Note: no Content-Security-Policy on purpose - the client uses
		# inline styles; add one only together with app-side changes.
	}

	# WebSockets are proxied automatically by Caddy.
	reverse_proxy pikdame:8080 {
		# Pass the real client IP for the app's IP-based rate limits
		# (the app must run with PIKDAME_TRUST_PROXY=1).
		header_up X-Forwarded-For {remote_host}
	}

	# JSON access log to the shared volume - CrowdSec tails this file
	# (container logs keep errors/runtime messages on stdout).
	# Access log exists ONLY for CrowdSec's attack detection. Retention is
	# deliberately short (privacy policy promises <= 48h): small rolls, two
	# files max, hard age cap. For debugging beyond that window, raise
	# roll_keep_for temporarily and reload - do not forget to lower it again.
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 2
			roll_keep_for 48h
		}
		format json
	}
}
