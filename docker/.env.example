# Pik Dame - environment template for production secrets.
# Copy to ".env" (git-ignored), fill in, then enable the env_file block in
# your compose file. Never commit the real .env.

# Password for the bundled PostgreSQL container (account database).
# The app's PIKDAME_DATABASE_URL in the compose files picks it up.
POSTGRES_PASSWORD=change-me

# Base URL used in account confirmation links
PIKDAME_BASE_URL=https://spiel.pikdame.online

# SMTP mail server (until configured, confirmation links go to the server log)
PIKDAME_SMTP_HOST=smtp.example.com
PIKDAME_SMTP_PORT=587
PIKDAME_SMTP_SECURE=starttls
PIKDAME_SMTP_USER=noreply@pikdame.online
PIKDAME_SMTP_PASS=change-me
PIKDAME_MAIL_FROM=Pik Dame <noreply@pikdame.online>
