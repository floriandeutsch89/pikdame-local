# Pik Dame - environment template (non-sensitive configuration only).
# Copy to ".env" (git-ignored). Real secrets (DB/SMTP passwords) do NOT
# belong here - they live as files under secrets/ (see docker-compose.prod.yml).

# --- Production stack (docker-compose.prod.yml) ---
# Domain served by Caddy (TLS certificate is obtained automatically via ACME)
PIKDAME_DOMAIN=play.pikdame.online
# ACME account e-mail for Let's Encrypt (expiry notices)
ACME_EMAIL=you@example.org
# CrowdSec bouncer key - create AFTER the first start:
#   docker compose -f docker-compose.prod.yml exec crowdsec cscli bouncers add caddy-bouncer
# then paste the printed key here and restart caddy.
CROWDSEC_API_KEY=create-with-cscli-bouncers-add

# SMTP identity (password -> secrets/smtp_password.txt; host/servername are
# preconfigured for Mailgun EU in docker-compose.prod.yml)
PIKDAME_SMTP_USER=postmaster@pikdame.online
PIKDAME_MAIL_FROM=Pik Dame <noreply@pikdame.online>

# --- Simple stacks only (docker-compose.yml / docker-compose.ghcr.yml) ---
# These interpolate the DB password directly; the prod stack uses
# secrets/db_password.txt instead.
POSTGRES_PASSWORD=change-me

# --- SMTP (non-secret parts; the password goes to secrets/smtp_password.txt
#     in prod, or PIKDAME_SMTP_PASS here for the simple stacks) ---
# PIKDAME_SMTP_HOST=smtp.example.com
# PIKDAME_SMTP_PORT=587
# PIKDAME_SMTP_SECURE=starttls
# PIKDAME_SMTP_USER=noreply@example.org
# PIKDAME_MAIL_FROM=Pik Dame <noreply@example.org>
